# Copy this file to .env and fill in your values.
# docker-compose automatically loads .env from the project root.

# Required: your Anthropic API key
# Only the Celery worker needs this — the web and beat services do not.
ANTHROPIC_API_KEY=sk-ant-...

# Model used by the LeadQualificationAgent. Defaults to claude-sonnet-4-6 if unset.
# Use a smaller model (e.g. haiku) to reduce cost during development.
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# Required for Phase 2 web search tool
# BRAVE_API_KEY=BSA...

# Optional: override Django settings
# DJANGO_SECRET_KEY=change-me-in-production
# DEBUG=false
# ALLOWED_HOSTS=yourdomain.com

# Database and Redis are pre-configured for the Docker Compose stack.
# Override only if you're running services externally.
# DATABASE_URL=postgresql://lead_qualifier:lead_qualifier@localhost:5432/lead_qualifier
# REDIS_URL=redis://localhost:6379/0
